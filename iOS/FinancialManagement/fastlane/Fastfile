default_platform(:ios)

XCODEPROJ      = "FinancialManagement.xcodeproj"
SCHEME         = "FinancialManagement"
APP_IDENTIFIER = "com.dthedy.FinancialManagement"
TEAM_ID        = "F73L2977Q8"
PROFILE_NAME   = "match AppStore #{APP_IDENTIFIER}"

# Build an App Store Connect API key from CI env vars. Used for both signing
# (match) and uploading (TestFlight), so no Apple ID password / 2FA is needed.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_CONTENT"),
    is_key_content_base64: true,
    in_house: false
  )
end

platform :ios do
  # Creates a temporary keychain and tweaks settings so match/codesign work
  # on an ephemeral CI runner. No-op when run locally.
  before_all do
    setup_ci
  end

  desc "Build the Release (Prod) app and upload it to TestFlight"
  lane :beta do
    api_key = asc_api_key

    # Fetch (or, on first run, create) the distribution cert + App Store
    # provisioning profile, decrypt them, and install into the CI keychain.
    #
    # `setup_ci` (before_all) force-sets MATCH_READONLY=true on macOS CI so
    # builds never accidentally mint duplicate signing assets. That also blocks
    # the FIRST run, which legitimately must CREATE the cert + profile and store
    # them in the match repo. So we gate creation on our own variable that
    # setup_ci doesn't touch: set repo Variable MATCH_CREATE_CERTS=true for the
    # first successful run, then delete it so every later run stays read-only
    # and just reuses the stored assets.
    create_certs = ENV["MATCH_CREATE_CERTS"] == "true"

    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      readonly: !create_certs
    )

    # Apply manual signing to the APP TARGET ONLY. Passing CODE_SIGN_IDENTITY /
    # PROVISIONING_PROFILE_SPECIFIER globally via xcargs forces them onto every
    # target — including Swift Package dependencies (e.g. swift-crypto) that
    # don't support provisioning profiles, which fails the archive. Editing the
    # project's signing settings scopes them to just our target. (Edits the CI
    # checkout's pbxproj; not committed.)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: XCODEPROJ,
      targets: [SCHEME],
      team_id: TEAM_ID,
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: PROFILE_NAME
    )

    # Give every CI build a unique, increasing build number. The project uses
    # GENERATE_INFOPLIST_FILE, so CURRENT_PROJECT_VERSION drives the build
    # number; passing it via xcargs avoids editing tracked files.
    build_number = ENV["BUILD_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    # Supabase config. Config/Prod.xcconfig (which normally defines these) is
    # git-ignored and absent on CI, so without this the Info.plist `$(SUPABASE_URL)`
    # placeholders expand to empty strings and the app crashes on launch unwrapping
    # them (AppConfig.swift). Pass them as build settings so Info.plist substitution
    # gets the real values. ENV.fetch fails the build early if a secret is missing.
    supabase_url = ENV.fetch("SUPABASE_URL")
    supabase_anon_key = ENV.fetch("SUPABASE_ANON_KEY")

    build_app(
      project: XCODEPROJ,
      scheme: SCHEME,
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      export_options: {
        provisioningProfiles: { APP_IDENTIFIER => PROFILE_NAME }
      },
      xcargs: [
        "-allowProvisioningUpdates",
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "SUPABASE_URL=#{supabase_url.shellescape}",
        "SUPABASE_ANON_KEY=#{supabase_anon_key.shellescape}"
      ].join(" "),
      output_directory: "build",
      output_name: "FinancialManagement.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      distribute_external: false # internal testers get it as soon as Apple finishes processing
    )
  end

  desc "Compile only (no signing) to verify the project builds — good for PR checks"
  lane :build_check do
    run_tests(
      project: XCODEPROJ,
      scheme: SCHEME,
      destination: "generic/platform=iOS Simulator",
      build_for_testing: true,
      skip_detect_devices: true
    )
  end
end
